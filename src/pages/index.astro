---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import { listArticles } from '../lib/articles'

const articles = listArticles()
---

<BaseLayout title="Artikel-portfolio" description="En samling af artikler, analyser og projekter.">
	<div class="container">
		<header class="topbar">
			<div class="brand">
				<div class="brand-title">Artikel-portfolio</div>
				<div class="brand-subtitle">
					Klik på en artikel for at læse den fulde version. Du kan tilføje flere artikler ved at lægge filer i{' '}
					<strong>public/articles</strong>.
				</div>
			</div>
			<div class="badge">{articles.length} artikler</div>
		</header>

		<main class="grid">
			{articles.map((a) => (
				<article class="card">
					<a class="card-link" href={a.href}>
						<div class="card-header">
							<h2 class="card-title">{a.title}</h2>
							<div class="card-meta">{a.updatedAt ?? a.kind.toUpperCase()}</div>
						</div>
						{a.description && <p class="card-desc">{a.description}</p>}
						<div class="pill-row">
							<span class={`pill ${a.kind === 'html' ? 'gold' : ''}`}>{a.kind}</span>
							<span class="pill">klik for at åbne</span>
						</div>
					</a>
				</article>
			))}

			<article class="card card-add">
				<a
					class="card-link card-add-link"
					href="https://github.com/OskarMatras/article-portfolio/tree/main/public/articles"
					target="_blank"
					rel="noreferrer"
					aria-label="Tilføj en artikel (upload i public/articles på GitHub)"
				>
					<div class="add-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path
								d="M12 5v14M5 12h14"
								stroke="currentColor"
								stroke-width="2.5"
								stroke-linecap="round"
							/>
						</svg>
					</div>
					<div class="card-add-title">Tilføj artikel</div>
					<div class="card-add-subtitle">Upload en fil til <strong>public/articles</strong> på GitHub.</div>
				</a>
			</article>
		</main>
	</div>
</BaseLayout>
