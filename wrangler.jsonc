{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "article-portfolio",
  "compatibility_date": "2026-05-07",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "ARTICLES",
      "bucket_name": "article-portfolio-articles"
    }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }
}
